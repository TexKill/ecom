GHCR_OWNER=your-github-org-or-user
API_PORT=9000
NEXT_PUBLIC_API_URL=https://api.example.com

# Infrastructure env vars
POSTGRES_DB=ecom_commerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# API env vars
PORT=9000
LOG_LEVEL=info
MONGODB_URL=mongodb://mongodb:27017/ecom_catalog
POSTGRES_URL=postgresql://postgres:change_me@postgres:5432/ecom_commerce?schema=public
JWT_SECRET=your_jwt_secret_key
CORS_ORIGIN=https://shop.example.com
ENABLE_SEED_ROUTES=false
SEED_KEY=change_me
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=false
API_PUBLIC_URL=https://api.example.com
CLIENT_URL=https://shop.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20
LIQPAY_CALLBACK_RATE_LIMIT_WINDOW_MS=60000
LIQPAY_CALLBACK_RATE_LIMIT_MAX_REQUESTS=120
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=ecom
CACHE_TTL_SECONDS=60
